{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CSV Editor",
  "version": "0.1.0",
  "identifier": "software.krill.csv-editor",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CSV Editor",
        "width": 1200,
        "height": 760,
        "minWidth": 480,
        "minHeight": 360,
        "decorations": false,
        "resizable": true,
        "center": true,
        "backgroundColor": "#FAFAFF"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "cli": {
      "description": "A minimal CSV editor for Linux",
      "args": [
        {
          "name": "file",
          "index": 1,
          "takesValue": true,
          "description": "Path to a CSV file to open"
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "Office",
    "shortDescription": "CSV editor",
    "longDescription": "A minimal, single-window CSV editor for Linux. Open, edit, save. Excel-shaped grid, calm chrome, comma-separated.",
    "fileAssociations": [
      {
        "ext": ["csv"],
        "name": "CSV",
        "description": "Comma-separated values",
        "mimeType": "text/csv",
        "role": "Editor"
      }
    ],
    "linux": {
      "deb": {
        "section": "office",
        "priority": "optional",
        "desktopTemplate": "main.desktop"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
